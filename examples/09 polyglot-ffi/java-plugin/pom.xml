<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>dev.vatn.examples</groupId>
    <artifactId>polyglot-ffi-example</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>jar</packaging>
    <name>VATN Polyglot FFI Example</name>

    <properties>
        <java.version>25</java.version>
        <maven.compiler.source>${java.version}</maven.compiler.source>
        <maven.compiler.target>${java.version}</maven.compiler.target>
        <maven.compiler.release>${java.version}</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Enable FFM (Foreign Function and Memory API) - stable in Java 22+,
             no enable-preview needed in Java 25. Kept here for explicitness. -->
        <argLine.ffm>--enable-native-access=ALL-UNNAMED</argLine.ffm>
    </properties>

    <dependencies>
        <!-- JSON serialisation for the Python stdio bridge -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.17.2</version>
        </dependency>

        <!-- In a real standalone VATN plugin, you'd depend on:
             <dependency>
                 <groupId>dev.vatn</groupId>
                  <artifactId>vatn-api</artifactId>
                  <version>1.0-alpha.14</version>
                 <scope>provided</scope>
             </dependency>
        -->

        <!-- Test -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>5.11.0</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <release>${java.version}</release>
                    <!--
                        FFM is stable in Java 22+. No preview flags needed.
                        We add -Xlint:preview to catch any accidental preview API use.
                    -->
                    <compilerArgs>
                        <arg>-Xlint:all</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- Allow running VatnFfiDemo directly via: mvn exec:java -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.3.0</version>
                <configuration>
                    <mainClass>dev.vatn.examples.ffi.VatnFfiDemo</mainClass>
                    <!--
                        CRITICAL: FFM requires enable-native-access to call
                        native code from unnamed modules. Without this flag you
                        get an IllegalCallerException at runtime.
                    -->
                    <jvmArgs>
                        <jvmArg>--enable-native-access=ALL-UNNAMED</jvmArg>
                    </jvmArgs>
                </configuration>
            </plugin>

            <!-- Surefire needs the same flag to run tests that use FFM -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.0</version>
                <configuration>
                    <argLine>${argLine.ffm}</argLine>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.4.2</version>
                <configuration>
                    <archive>
                        <manifest>
                            <mainClass>dev.vatn.examples.ffi.VatnFfiDemo</mainClass>
                        </manifest>
                        <manifestEntries>
                            <!-- PF4J plugin metadata for VATN's plugin loader -->
                            <Plugin-Id>vatn-ffi-example</Plugin-Id>
                            <Plugin-Version>1.0.0</Plugin-Version>
                            <Plugin-Provider>VATN</Plugin-Provider>
                        </manifestEntries>
                    </archive>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
